{
  "name": "skellychart",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm run generate",
    "dev": "vite",
    "generate": "npm run generate:tiling-feasibility",
    "generate:tiling-feasibility": "tsx scripts/generate-tiling-feasibility.ts",
    "generate:aruco-dict": "tsx scripts/run-export-aruco-dict.ts",
    "verify:opencv-raster": "uv run --with opencv-contrib-python-headless python scripts/verify_charuco_raster.py",
    "build": "npm run generate && tsc -b && vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "tsx": "^4.19.4",
    "typescript": "~6.0.3",
    "vite": "^8.0.13"
  },
  "dependencies": {
    "qrcode": "^1.5.4"
  }
}
